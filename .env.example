# Kopiér til .env.local og udfyld med rigtige værdier.
# ALDRIG commit .env eller .env.local — de ligger i .gitignore.

# ── Supabase (klient + server) ──────────────────────────────────────────────
# Hent fra Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# Server-side only — bruges af admin-operationer (lib/supabase/admin.ts).
# Må ALDRIG eksponeres til klient. Regenerér hvis den lækker.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# ── App-konfiguration ──────────────────────────────────────────────────────
# Fuld URL til siden — bruges i auth-callbacks og e-mail-links.
# Lokalt: http://localhost:3000 • Prod: https://striq.dk (eller din domæne)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Komma-separeret liste over e-mails der har admin-adgang (garn-katalog-editor mv.)
EDITOR_EMAILS=admin@example.com

# Secret til /api/revalidate-endpoint. Skal være stærk i prod.
REVALIDATE_SECRET=change-me-in-prod

# ── Legacy (kun til scripts/migrate-stash-to-catalog.mjs) ──────────────────
# Scriptet falder tilbage til NEXT_PUBLIC_SUPABASE_URL hvis VITE_* ikke er sat.
# Kan udelades — behold kun hvis du kører det gamle script.
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
